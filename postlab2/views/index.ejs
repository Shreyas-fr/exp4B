<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Price Checker - Experiment 4B</title>
    <!-- Importing Bootstrap for instant, user-friendly styling -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { border-radius: 16px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .result-box { border-radius: 12px; background: linear-gradient(145deg, #e0f7fa 0%, #d4edd9 100%); border: 1px solid #b2ebf2; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 p-3">

<div class="container" style="max-width: 600px;">
    <!-- Required College Header -->
    <div class="text-center mb-4">
        <h5 class="fw-bold text-dark">Fr. Conceicao Rodrigues College of Engineering</h5>
        <h6 class="text-muted">Experiment 4B - Web Application Development with APIs</h6>
    </div>

    <div class="card p-4 p-md-5 bg-white border-0">
        <h2 class="text-center mb-4 text-primary fw-black">Live Crypto Tracker</h2>
        
        <form action="/check" method="POST" class="mb-4">
            <div class="mb-3">
                <label for="symbol" class="form-label text-muted fw-bold">Enter Trading Pair Symbol</label>
                <input type="text" class="form-control form-control-lg bg-light" id="symbol" name="symbol" placeholder="e.g. BTC-USD, ETH-USD" required>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">Check Live Price</button>
        </form>

        <!-- Error Handling Display -->
        <% if (error) { %>
            <div class="alert alert-danger fw-bold border-0 shadow-sm" role="alert">
                <%= error %>
            </div>
        <% } %>

        <!-- Successful Data Presentation -->
        <% if (data) { %>
            <div class="result-box p-4 shadow-sm text-dark mt-2">
                <h4 class="fw-bold mb-4 text-center border-bottom border-info pb-3">Market Data: <span class="text-primary"><%= data.symbol %></span></h4>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold">Last Traded Price</span>
                    <span class="fs-4 fw-black text-success">$<%= data.last_trade_price.toLocaleString() %></span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold">24H Price Tracker</span>
                    <span class="fs-5 fw-bold">$<%= data.price_24h.toLocaleString() %></span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-bold">24H Trade Volume</span>
                    <span class="fs-5 fw-bold"><%= data.volume_24h.toLocaleString() %></span>
                </div>
            </div>
        <% } %>
    </div>
</div>

</body>
</html>
